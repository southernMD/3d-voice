{
  "headers": [
    {
      "source": "/bcut-upload-proxy/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "PUT, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "*" },
        { "key": "Access-Control-Expose-Headers", "value": "ETag, etag" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/music-api/(.*)",
      "destination": "/api/resolve?path=$1"
    },
    {
      "source": "/gdstudio-api/(.*)",
      "destination": "/api/gdstudio?path=$1"
    },
    {
      "source": "/bili-api/(.*)",
      "destination": "/api/bili?path=$1"
    },
    {
      "source": "/bcut-api/(.*)",
      "destination": "/api/bcut-api?path=$1"
    },
    {
      "source": "/bcut-upload/(.*)",
      "destination": "/api/bcut-upload?path=$1"
    },
    {
      "source": "/bcut-upload-proxy/http/:domain/:path*",
      "destination": "http://:domain/:path*"
    },
    {
      "source": "/bcut-upload-proxy/https/:domain/:path*",
      "destination": "https://:domain/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}